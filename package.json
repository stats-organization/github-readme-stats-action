{
  "name": "github-readme-stats-action",
  "version": "0.1.0",
  "description": "Generate GitHub Readme Stats cards in GitHub Actions",
  "type": "module",
  "license": "MIT",
  "private": true,
  "main": "index.js",
  "scripts": {
    "test": "vitest",
    "format": "prettier --write .",
    "lint-staged": "lint-staged",
    "lint:knip": "knip",
    "prepare": "husky install"
  },
  "dependencies": {
    "@actions/core": "^2.0.1",
    "github-readme-stats": "github:readme-tools/github-readme-stats"
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "knip": "6.2.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "vitest": "4.1.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,json,jsonc,yaml,yml}": "prettier --write"
  },
  "engines": {
    "node": ">=22"
  }
}
